# Example test-size ceiling. Adjust test locations and suffixes for the project, or delete it.
reason=test file exceeds 2500 lines; split it into focused test modules
max_lines=2500
glob=test/**,tests/**,spec/**,**/*.test.ts,**/*.test.tsx,**/*.test.js,**/*.test.jsx,**/*.test.mjs,**/*.test.cjs,**/*.spec.ts,**/*.spec.tsx,**/*.spec.js,**/*.spec.jsx,**/*.spec.mjs,**/*.spec.cjs,**/*.test.py,**/*.spec.rb
exclude=**/node_modules/**,**/dist/**,**/build/**,**/vendor/**,**/vendored/**,**/generated/**
# Based on https://github.com/masuidrive/pdh/blob/XXXXXXX/templates/checks/example-max-test-lines.check
